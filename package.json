{
  "name": "test-data-generator",
  "version": "0.0.1",
  "private": true,
  "description": "A simple web app for generating test data.",
  "keywords": [
    "generator",
    "test data"
  ],
  "license": "MIT",
  "author": "luth1um",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "vite",
    "clean": "node -e \"['dist', 'playwright-report', 'test-results'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\"",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix --deny-warnings",
    "build": "vite build",
    "build-cloudflare-pages": "vite build --base=/",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e-ui": "playwright test --ui",
    "e2e-update-snapshots": "playwright test --update-snapshots",
    "all-checks": "npm run clean && npm run format && npm run lint && npm run build && npm run test && npm run e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "3.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "vite": "8.0.12",
    "vitest": "4.1.5"
  },
  "nano-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
